{
  "type_id": "healthbar",
  "display_name": "Health Bar",
  "category": "StatusDisplay",
  "default_size": {
    "x": 200,
    "y": 30
  },
  "default_anchor": "TopLeft",
  "description": "Displays player's current health as a horizontal bar",
  "properties_schema": {
    "max_value": {
      "type": "int",
      "default": 100,
      "description": "Maximum health value"
    },
    "show_numbers": {
      "type": "bool",
      "default": true,
      "description": "Show numeric health value"
    },
    "bar_color": {
      "type": "color",
      "default": [
        255,
        0,
        0
      ],
      "description": "RGB color of health bar"
    },
    "background_color": {
      "type": "color",
      "default": [
        64,
        64,
        64
      ],
      "description": "RGB color of background"
    },
    "border_thickness": {
      "type": "int",
      "default": 2,
      "description": "Border thickness in pixels"
    }
  }
}
