# Wrapper Dockerfile for devcontainers
# Provide a valid default to avoid the InvalidDefaultArgInFrom warning
ARG BASE_IMAGE=maishuji/dc-kos-image:15.2.1-dev-08feb26-gdb-kp08feb26

FROM ${BASE_IMAGE}

# Properly clear any devcontainer metadata from the base image
LABEL devcontainer.metadata="[]"

# (Optional) Set your default non-root user if your image contains it
USER non-root
