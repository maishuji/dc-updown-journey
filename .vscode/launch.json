{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug UDJourney Editor (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/editor-linux/udjourney_editor",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/editor-linux",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Configure CMake (Linux)",
            "miDebuggerPath": "/usr/bin/gdb",
            "logging": {
                "engineLogging": false
            }
        },
        {
            "name": "Debug Tests (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/editor-linux/tilepanel_tests",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/editor-linux",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug (Linux)",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Attach to Dreamcast (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/udjourney/updown-journey.elf",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "sh-elf-gdb",
            "miDebuggerServerAddress": "127.0.0.1:2159",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set architecture to SH4",
                    "text": "-gdb-set architecture sh4",
                    "ignoreFailures": true
                }
            ],
            "logging": {
                "engineLogging": true,
                "trace": true,
                "traceResponse": true
            }
        }
    ],
    "inputs": [
        {
            "id": "dreamcastIP",
            "type": "promptString",
            "description": "Dreamcast IP address (e.g., 192.168.0.14)",
            "default": "192.168.0.14"
        }
    ]
}
